# DQIII8 — Environment Configuration
# Copy this file to config/.env and fill in your values.
# Never commit config/.env to version control.

# ── Required for Tier B (free cloud) ─────────────────────────────────
GROQ_API_KEY=           # Get from console.groq.com (free)
# TOGETHER_API_KEY=     # Optional alternative to Groq: together.ai (free tier)

# ── Required for Tier A (paid) — optional, system works without it ────
# ANTHROPIC_API_KEY=    # Get from console.anthropic.com

# ── Optional: additional providers ───────────────────────────────────
# OPENAI_API_KEY=       # OpenAI (gpt-4o, gpt-4o-mini)
# OPENROUTER_API_KEY=   # OpenRouter — access many models via one key

# ── Telegram bot — optional feature ──────────────────────────────────
# TELEGRAM_BOT_TOKEN=   # Get from @BotFather on Telegram
# TELEGRAM_CHAT_ID=     # Your Telegram chat ID (send /start to your bot)

# ── Ollama ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Optional integrations ─────────────────────────────────────────────
# GITHUB_TOKEN=         # For github_researcher.py (5000 req/h vs 60 without)
# GEMINI_API_KEY=       # For /gemini-review workflow
