{"template_name":"Software Architecture Design","agent":"software_engineering","sub_agent":"architecture","required_fields":[{"name":"application_type","type":"string","description":"What the software does","example":"Food delivery platform"},{"name":"expected_users","type":"number","description":"Expected concurrent users","example":10000},{"name":"tech_stack_preference","type":"string","description":"Preferred languages/frameworks","example":"Python + React"},{"name":"features","type":"list","description":"Core features needed","example":["Authentication","Payment","Real-time tracking","Notifications"]}],"optional_fields":[{"name":"budget","type":"string","description":"Infrastructure budget","example":"$500/month"},{"name":"deployment","type":"string","description":"Cloud provider preference","example":"AWS"},{"name":"timeline_weeks","type":"number","description":"Development timeline","example":16},{"name":"team_size","type":"number","description":"Number of developers","example":3}],"equations":{"requests_per_second":"concurrent_users * avg_requests_per_minute / 60","database_connections":"rps * avg_query_time_ms / 1000","storage_growth":"users * avg_data_per_user_mb * growth_rate","uptime_nines":"(total_time - downtime) / total_time * 100","cost_per_user":"monthly_infra_cost / monthly_active_users"},"example_prompt":"Design a microservices architecture for a food delivery app handling 10,000 concurrent orders with auth, payment, and real-time tracking"}
