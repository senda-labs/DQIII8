{"template_name":"Marketing Campaign Plan","agent":"marketing","sub_agent":"digital_marketing","required_fields":[{"name":"product_or_service","type":"string","description":"What you are marketing","example":"Organic cleaning products"},{"name":"target_audience","type":"string","description":"Who you want to reach","example":"Eco-conscious homeowners 25-45"},{"name":"budget_monthly","type":"number","description":"Monthly marketing budget in USD/EUR","example":2000},{"name":"channels","type":"list","description":"Preferred marketing channels","example":["Instagram","Google Ads","SEO"]},{"name":"goal","type":"string","description":"Primary campaign objective","example":"Generate 100 leads per month"}],"optional_fields":[{"name":"competitors","type":"list","description":"Main competitors","example":["Brand A","Brand B"]},{"name":"timeline_weeks","type":"number","description":"Campaign duration","example":12},{"name":"existing_assets","type":"string","description":"Current website, social media, etc.","example":"Website + Instagram 5K followers"}],"equations":{"CAC":"total_marketing_spend / new_customers_acquired","ROAS":"revenue_from_ads / ad_spend","CTR":"clicks / impressions * 100","conversion_rate":"conversions / total_visitors * 100","LTV":"avg_order_value * purchase_frequency * customer_lifespan","break_even_ROAS":"1 / profit_margin"},"example_prompt":"Create a marketing campaign for organic cleaning products targeting eco-conscious homeowners, $2000/month budget, Instagram + Google Ads"}
