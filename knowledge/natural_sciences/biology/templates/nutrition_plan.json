{"template_name":"Nutrition Plan","agent":"biology","sub_agent":"nutrition","required_fields":[{"name":"height_cm","type":"number","description":"Client height in cm","example":182},{"name":"weight_kg","type":"number","description":"Current weight in kg","example":78.65},{"name":"age","type":"number","description":"Client age","example":28},{"name":"sex","type":"string","description":"Biological sex (M/F)","example":"M"},{"name":"activity_level","type":"string","description":"Sedentary/Moderate/Active/Athlete","example":"Active"},{"name":"goal","type":"string","description":"Weight loss/Muscle gain/Recomposition/Maintenance","example":"Recomposition"},{"name":"target_change_kg","type":"number","description":"Target weight change in kg","example":5}],"optional_fields":[{"name":"allergies","type":"list","description":"Food allergies","example":["lactose","gluten"]},{"name":"diet_preference","type":"string","description":"Omnivore/Vegetarian/Vegan","example":"Omnivore"},{"name":"budget_weekly_eur","type":"number","description":"Weekly food budget","example":80},{"name":"current_diet","type":"string","description":"Description of current eating habits","example":"3 meals/day, high carb, low protein"}],"equations":{"BMR_male":"88.362 + (13.397 * weight_kg) + (4.799 * height_cm) - (5.677 * age)","BMR_female":"447.593 + (9.247 * weight_kg) + (3.098 * height_cm) - (4.330 * age)","TDEE":"BMR * activity_multiplier","activity_multipliers":{"Sedentary":1.2,"Moderate":1.55,"Active":1.725,"Athlete":1.9},"protein_target":"1.6-2.2 g/kg for muscle gain, 1.2-1.6 g/kg for maintenance","caloric_surplus":"+300-500 kcal/day for muscle gain","caloric_deficit":"-300-500 kcal/day for fat loss"},"example_prompt":"Create a nutrition plan for a 28yo male, 182cm, 78.65kg, active, goal: lose 5kg fat and gain 5kg muscle over 16 weeks"}
