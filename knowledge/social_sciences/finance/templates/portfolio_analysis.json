{"template_name":"Portfolio Risk Analysis","agent":"finance","sub_agent":"risk_management","required_fields":[{"name":"assets","type":"list","description":"List of assets with ticker and allocation %","example":[{"ticker":"SPY","allocation":0.60},{"ticker":"BND","allocation":0.25}]},{"name":"total_value","type":"number","description":"Total portfolio value in USD","example":100000},{"name":"confidence_level","type":"number","description":"VaR confidence level (0.90-0.99)","example":0.95},{"name":"time_horizon","type":"string","description":"Analysis period","example":"1 year"}],"optional_fields":[{"name":"risk_free_rate","type":"number","description":"Annual risk-free rate","example":0.045},{"name":"benchmark","type":"string","description":"Benchmark index","example":"S&P 500"}],"equations":{"VaR_parametric":"VaR = Z_score × σ_portfolio × √t × portfolio_value","VaR_95_Z":"Z = 1.645 for 95%, Z = 2.326 for 99%","portfolio_variance":"σ²_p = Σ Σ w_i w_j σ_ij","sharpe_ratio":"(R_p - R_f) / σ_p","beta":"Cov(R_i, R_m) / Var(R_m)"},"example_prompt":"Analyze the risk profile of a $100K portfolio: 60% SPY, 25% BND, 10% GLD, 5% BTC at 95% confidence"}
