{"template_name":"Business Plan","agent":"business","sub_agent":"startup","required_fields":[{"name":"business_idea","type":"string","description":"What the business does","example":"Digital marketing agency for cleaning brands"},{"name":"target_market","type":"string","description":"Who your customers are","example":"Small to medium cleaning product manufacturers"},{"name":"location","type":"string","description":"Where the business operates","example":"London, UK (remote-first)"},{"name":"initial_investment","type":"number","description":"Available startup capital","example":5000}],"optional_fields":[{"name":"team_size","type":"number","description":"Number of founders/employees","example":1},{"name":"timeline_months","type":"number","description":"Months to profitability target","example":6},{"name":"revenue_model","type":"string","description":"How you make money","example":"Monthly retainer + project fees"},{"name":"unique_advantage","type":"string","description":"What makes you different","example":"Specialized in cleaning industry SEO"}],"equations":{"break_even_months":"fixed_costs / (avg_monthly_revenue - variable_costs)","monthly_burn_rate":"total_monthly_expenses","runway_months":"total_capital / monthly_burn_rate","gross_margin":"(revenue - COGS) / revenue * 100","customer_payback_period":"CAC / (monthly_revenue_per_customer * gross_margin)"},"example_prompt":"Create a business plan for a digital marketing agency specializing in cleaning products, based in London, starting with 5000 GBP"}
