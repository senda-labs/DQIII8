# JARVIS .gitignore

# Base de datos (no versionar — demasiado pesada y sensible)
database/*.db
database/*.db-wal
database/*.db-shm

# Worktrees de agentes (efímeros)
.claude/worktrees/

# Skills cache (se descarga con /skills-sync)
skills-registry/cache/everything-claude-code/
skills-registry/cache/awesome-subagents/

# Flags de estado efímeros
tasks/audit_pending.flag
tasks/status.md

# Resultados de sesión (rotan)
tasks/results/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Windows
Thumbs.db
desktop.ini
*.lnk

# Secrets (nunca deben llegar aquí)
.env
*.pem
*.key
id_rsa
id_ed25519
venv/
# Aider
.aider.chat.history.md
.aider.input.history
.aider*

# Skills cache (repos externos — no versionar)
skills-registry/cache/

# Logs internos
database/system_metrics.log
database/audit_reports/jarvis_bot.log
objectives/active/
objectives/failed/

# Reportes efímeros de tareas (se regeneran, no versionar)
tasks/gemini_reports/
tasks/github_reports/
tasks/precompact_state.json
tasks/diagnostic_*.md
tasks/jarvis_architecture_v1.*
tasks/*.zip
tasks/*.pdf
tasks/*.html

# Archivos grandes temporales
*.zip
*.tar.gz

# Archivos de decisiones generados automáticamente
decisions/adr-compliance.json
tasks/permission_rejection.json
