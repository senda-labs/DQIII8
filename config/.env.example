# DQIII8 — Environment Configuration
# Copy this file to config/.env and fill in your values.
# Never commit .env to version control.

# ── Core ──────────────────────────────────────────────────────────────
# Root directory (auto-detected from script location if not set)
# DQIII8_ROOT=/path/to/dqiii8

# ── Telegram Bot ──────────────────────────────────────────────────────
DQIII8_BOT_TOKEN=           # Telegram bot token from @BotFather
TELEGRAM_CHAT_ID=           # Your Telegram chat ID

# ── AI Providers ──────────────────────────────────────────────────────
GROQ_API_KEY=               # Groq API key (free tier: llama-3.3-70b)
OPENROUTER_API_KEY=         # OpenRouter API key (optional fallback)
# ANTHROPIC_API_KEY=        # Only needed for Tier A (claude-sonnet)

# ── Ollama ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Optional integrations ─────────────────────────────────────────────
# GITHUB_TOKEN=             # For github_researcher.py (5000 req/h vs 60)
# GEMINI_API_KEY=           # For /gemini-review workflow
