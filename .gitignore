# JARVIS .gitignore

# Database (not versioned — too large and sensitive)
database/*.db
database/*.db-wal
database/*.db-shm

# Agent worktrees (ephemeral)
.claude/worktrees/

# Skills cache (downloaded via /skills-sync)
skills-registry/cache/everything-claude-code/
skills-registry/cache/awesome-subagents/

# Ephemeral state flags
tasks/audit_pending.flag
tasks/status.md

# Session results (rotate)
tasks/results/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Windows
Thumbs.db
desktop.ini
*.lnk

# Secrets (nunca deben llegar aquí)
.env
*.pem
*.key
id_rsa
id_ed25519
venv/
# Aider
.aider.chat.history.md
.aider.input.history
.aider*

# Skills cache (repos externos — no versionar)
skills-registry/cache/

# Logs internos
database/system_metrics.log
database/audit_reports/jarvis_bot.log
database/audit_reports/*.md
database/audit-*.md

# Directorios de tareas internas (no publicar)
tasks/integration_proposals/
tasks/research_queue/
tasks/test_results/

# Archivos internos del sistema
.jarvis_proposito
objectives/active/
objectives/failed/

# Reportes efímeros de tareas (se regeneran, no versionar)
tasks/gemini_reports/
tasks/github_reports/
tasks/precompact_state.json
tasks/diagnostic_*.md
tasks/jarvis_architecture_v1.*
tasks/*.zip
tasks/*.pdf
tasks/*.html

# Archivos grandes temporales
*.zip
*.tar.gz

# Archivos de decisiones generados automáticamente
decisions/adr-compliance.json
tasks/permission_rejection.json

# Node (Claude Code)
node_modules/
.mcp.json

# === Internal/Private — never push to public repo ===
CLAUDE.md
CLAUDE.md.save*
claude-progress.txt
PLAN_MAESTRO.md
00_DASHBOARD.md
CHANGELOG.md
pyproject.toml

# Internal directories
context/
sessions/
projects/
tasks/
decisions/
database/audit_reports/
database/system_metrics.log
database/qdrant/

# MCP local config
.claude/.mcp.json
.claude/settings.json

# Internal bin scripts
bin/script_benchmark.py

# OS files
.DS_Store
*.swp
*.swo
*~
