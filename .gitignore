# DQIII8 .gitignore

# Database (not versioned — too large and sensitive)
database/*.db
database/*.db-wal
database/*.db-shm

# Config with real keys (example file IS committed, real file is NOT)
config/.env

# Claude Code credentials
.claude/.credentials.json

# Pytest
.pytest_cache/

# Nightly report (regenerated each run)
tasks/nightly-report.md

# Agent worktrees (ephemeral)
.claude/worktrees/

# Skills cache (downloaded via /skills-sync)
skills-registry/cache/everything-claude-code/
skills-registry/cache/awesome-subagents/

# Ephemeral state flags
tasks/audit_pending.flag
tasks/status.md

# Session results (rotate)
tasks/results/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Windows
Thumbs.db
desktop.ini
*.lnk

# Secrets (should never end up here)
.env
*.pem
*.key
id_rsa
id_ed25519
venv/
# Aider
.aider.chat.history.md
.aider.input.history
.aider*

# Skills cache (external repos — do not version)
skills-registry/cache/

# Internal logs
database/system_metrics.log
database/audit_reports/jarvis_bot.log
database/audit_reports/*.md
database/audit-*.md

# Internal task directories (do not publish)
tasks/integration_proposals/
tasks/research_queue/
tasks/test_results/

# Internal system files
.jarvis_proposito
objectives/active/
objectives/failed/

# Ephemeral task reports (regenerated — do not version)
tasks/gemini_reports/
tasks/github_reports/
tasks/precompact_state.json

# Premium features (not included in free tier)
knowledge/*/user_uploads/
knowledge/**/PREMIUM_*


# Premium knowledge (not in public tier)
knowledge/*/PREMIUM_*
knowledge/*/*/PREMIUM_*
knowledge/**/templates/
tasks/diagnostic_*.md
tasks/jarvis_architecture_v1.*
tasks/*.zip
tasks/*.pdf
tasks/*.html

# Large temporary files
*.zip
*.tar.gz

# Automatically generated decision files
decisions/adr-compliance.json
tasks/permission_rejection.json

# Node (Claude Code)
node_modules/
.mcp.json

# === Internal/Private — never push to public repo ===
CLAUDE.md.save*
claude-progress.txt
PLAN_MAESTRO.md
00_DASHBOARD.md
CHANGELOG.md
!docs/CHANGELOG.md
pyproject.toml

# Internal directories
context/
sessions/
projects/
tasks/
decisions/
database/audit_reports/
database/system_metrics.log
database/qdrant/

# User projects — track placeholder only, never project contents
my-projects/*/

# Archive — not for public consumption
bin/archive/

# Personal skills — only README.md is public
skills-registry/custom/*
!skills-registry/custom/README.md

# MCP local config
.claude/.mcp.json
.claude/settings.json

# Internal bin scripts
bin/script_benchmark.py

# OS files
.DS_Store
*.swp
*.swo
*~
database/.dashboard_token
database/system_profile.json

# Editor files (from ECC reference)
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# Additional env patterns
.env.local
.env.*.local

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Build outputs
dist/
build/
.cache/

# Test coverage
coverage/
.nyc_output/

# Logs (generic)
logs/
