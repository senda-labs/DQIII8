# DQIII8 — Environment Variables
# Copy this file to .env in the project root: cp config/.env.example .env
# Then fill in your values. All keys are optional unless marked REQUIRED.

# ── Tier 1: Local Models (free, via Ollama) ──────────────────────────
# No API key needed. Ollama runs locally.
# install.sh will set up Ollama + qwen2.5-coder:7b automatically.

# ── Tier 2: Cloud Models (free tiers) ────────────────────────────────
# Groq — free tier, used for code review and analysis
GROQ_API_KEY=

# OpenRouter — free models for media/content tasks
OPENROUTER_API_KEY=

# ── Tier 3: Paid Models (optional, highest capability) ───────────────
# Only needed for complex architecture, finance, or creative tasks
# ANTHROPIC_API_KEY=

# ── Integrations (all optional) ──────────────────────────────────────
# Telegram bot for notifications and remote control
JARVIS_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Gemini — used for external code review
GEMINI_API_KEY=

# Hugging Face — model downloads
HF_TOKEN=

# Fal.ai — image/video generation
FAL_API_KEY=

# ElevenLabs — text-to-speech
ELEVENLABS_API_KEY=

# Exa — web search for research agent
EXA_API_KEY=

# GitHub — increases API rate limit from 60 to 5000 req/h
# GITHUB_TOKEN=
