{
  "env": {
    "JARVIS_ROOT": "/root/jarvis",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/session_start.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /usr/lib/node_modules/context-mode/hooks/sessionstart.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/pre_tool_use.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Eres el agente Shannon de seguridad de JARVIS. Evalua si esta operacion es segura. Tool: $TOOL_NAME. Input: $TOOL_INPUT. Responde SOLO con JSON: {\"allow\": true/false, \"risk\": \"LOW/MEDIUM/HIGH\", \"reason\": \"una linea\"}. Bloquea solo si detectas: escritura a .env o secrets, SQL sin parametrizar, o exfiltracion de datos. En cualquier otro caso allow: true.",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/post_tool_use.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /usr/lib/node_modules/context-mode/hooks/posttooluse.mjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/semgrep_scan.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/semgrep_scan.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/precompact.py"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /usr/lib/node_modules/context-mode/hooks/precompact.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/stop.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/stop.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/subagent_start.py"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/postcompact.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/user_prompt_submit.py"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/post_tool_use_failure.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /root/jarvis/.claude/hooks/permission_request.py"
          }
        ]
      }
    ]
  }
}
